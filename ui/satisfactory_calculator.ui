  <property name="styleSheet">
   <string>QMainWindow {
    background-color: #1a1a1a;
    color: #e0e0e0;
}

QWidget {
    background-color: #1a1a1a;
    color: #e0e0e0;
}

QLabel {
    color: #e0e0e0;
    font-weight: 500;
}

QLineEdit {
    background-color: #2a2a2a;
    color: #ffb800;
    border: 2px solid #444444;
    border-radius: 4px;
    padding: 6px;
    font-weight: bold;
    font-size: 13px;
}

QLineEdit:focus {
    border: 2px solid #ffb800;
    background-color: #252525;
}

QListWidget {
    background-color: #242424;
    color: #e0e0e0;
    border: 2px solid #333333;
    border-radius: 4px;
    outline: none;
}

QListWidget::item {
    padding: 8px;
    border-bottom: 1px solid #333333;
}

QListWidget::item:hover {
    background-color: #333333;
}

QListWidget::item:selected {
    background-color: #ffb800;
    color: #1a1a1a;
    font-weight: bold;
}

QTreeWidget {
    background-color: #242424;
    color: #e0e0e0;
    border: 2px solid #333333;
    border-radius: 4px;
    outline: none;
    gridline-color: #333333;
}

QTreeWidget::item {
    padding: 4px;
    border-bottom: 1px solid #2a2a2a;
}

QTreeWidget::item:hover {
    background-color: #2f2f2f;
}

QTreeWidget::item:selected {
    background-color: #ffb800;
    color: #1a1a1a;
}

QHeaderView::section {
    background-color: #2a2a2a;
    color: #e0e0e0;
    padding: 5px;
    border: none;
    border-right: 1px solid #333333;
}

QCheckBox {
    color: #e0e0e0;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 3px;
}

QCheckBox::indicator:unchecked {
    background-color: #2a2a2a;
    border: 2px solid #444444;
}

QCheckBox::indicator:unchecked:hover {
    border: 2px solid #ffb800;
}

QCheckBox::indicator:checked {
    background-color: #ff8c00;
    border: 2px solid #ff8c00;
}

QCheckBox::indicator:checked:hover {
    background-color: #ffb800;
    border: 2px solid #ffb800;
}

QCheckBox::indicator:checked:pressed {
    background-color: #e67e00;
    border: 2px solid #e67e00;
}

QPushButton {
    background-color: #ff8c00;
    color: #000000;
    border: none;
    border-radius: 6px;
    padding: 10px 24px;
    font-weight: bold;
    font-size: 13px;
}

QPushButton:hover {
    background-color: #ffb800;
}

QPushButton:pressed {
    background-color: #e67e00;
}

QSpinBox, QDoubleSpinBox {
    background-color: #2a2a2a;
    color: #ffb800;
    border: 2px solid #444444;
    border-radius: 4px;
    padding: 5px;
    font-weight: bold;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 2px solid #ffb800;
}

QComboBox {
    background-color: #2a2a2a;
    color: #e0e0e0;
    border: 2px solid #444444;
    border-radius: 4px;
    padding: 5px;
}

QComboBox:focus {
    border: 2px solid #ffb800;
}

QComboBox QAbstractItemView {
    background-color: #2a2a2a;
    color: #e0e0e0;
    border: 2px solid #444444;
    selection-background-color: #ffb800;
    selection-color: #1a1a1a;
}

QScrollBar:vertical {
    background-color: #242424;
    width: 12px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #555555;
    border-radius: 6px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #ffb800;
}

QScrollBar:horizontal {
    background-color: #242424;
    height: 12px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #555555;
    border-radius: 6px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #ffb800;
}

QGroupBox {
    color: #e0e0e0;
    border: 2px solid #333333;
    border-radius: 6px;
    margin-top: 12px;
    padding-top: 8px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 3px;
}
</string>
